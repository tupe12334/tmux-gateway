{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(cargo build:*)",
      "Bash(cargo run:*)",
      "Bash(make build:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(cargo fmt:*)",
      "Bash(tmux new-session:*)",
      "Bash(cargo add:*)",
      "Bash(cargo doc:*)",
      "Bash(git status:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo check:*)"
    ],
    "deny": ["Bash(gh issue create:*)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm dlx block-no-verify"
          }
        ]
      }
    ]
  }
}
