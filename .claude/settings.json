{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(cargo build:*)",
      "Bash(cargo run:*)",
      "Bash(make build:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm dlx block-no-verify"
          }
        ]
      }
    ]
  }
}
