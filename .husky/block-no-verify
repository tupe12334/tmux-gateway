#!/usr/bin/env sh
# Source this file in your shell config (~/.bashrc, ~/.zshrc) to block --no-verify
# Example: . "$(git rev-parse --show-toplevel)/.husky/block-no-verify"

git() {
  for arg in "$@"; do
    if [ "$arg" = "--no-verify" ]; then
      echo "Error: --no-verify is blocked in this repository."
      echo "Git hooks are required to maintain code quality."
      return 1
    fi
  done
  command git "$@"
}
