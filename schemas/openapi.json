{
  "openapi": "3.1.0",
  "info": {
    "title": "tmux-gateway",
    "description": "REST API for interacting with local tmux sessions",
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [],
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Health check",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sessions": {
      "get": {
        "tags": [],
        "operationId": "list_sessions",
        "responses": {
          "200": {
            "description": "List tmux sessions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SessionResponse"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Failed to list sessions"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "SessionResponse": {
        "type": "object",
        "required": [
          "name",
          "windows",
          "created",
          "attached"
        ],
        "properties": {
          "attached": {
            "type": "boolean"
          },
          "created": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "windows": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      }
    }
  }
}